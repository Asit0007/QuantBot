# QuantBot — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to git. It is already in .gitignore.

# ── Binance API (for live trading only) ──────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ── Telegram Bot (notifier.py) ───────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy token
# 2. Message @userinfobot → copy your chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Shared data directory ────────────────────────────────────────
# Where bot_state.json, trade_log.csv, corpus_state.json are written.
# In Docker this is the mounted volume path inside the container.
DATA_DIR=/app/data

# ── Dashboard config ─────────────────────────────────────────────
DASHBOARD_PORT=8050
DASHBOARD_HOST=0.0.0.0
DASHBOARD_REFRESH_MS=15000

# ── Oracle Cloud SSH (used by CI/CD — set as GitHub Secrets) ─────
# Do not put these in this file. Add to GitHub repo → Settings → Secrets.
# ORACLE_HOST=your.oracle.vm.ip
# ORACLE_USER=ubuntu
# ORACLE_SSH_KEY=-----BEGIN OPENSSH PRIVATE KEY-----...
